{
  "name": "tss-login-extension",
  "displayName": "PSS IDE",
  "description": "IDE for PSS",
  "version": "0.0.1",
  "publisher": "your-name",
  "engines": {
    "vscode": "^1.85.0"
  },
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "pss.login",
        "title": "PSS: Login"
      },
      {
        "command": "pss.check",
        "title": "CHECK"
      }
    ],
    "menus": {
			"editor/title": [
				{
					"command": "pss.check",
					"group": "navigation"
				}
			]
		}

  },
  "scripts": {
    "compile": "tsc -p ./"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
  }
}