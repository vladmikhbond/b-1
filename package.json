{
  "name": "b1",
  "displayName": "b1",
  "description": "IDE for PSS",
  "version": "0.9.4",
  "publisher": "vladmikhbond",
  "repository": {
    "type": "git",
    "url": "https://github.com/vladmikhbond/b-1.git"
  },
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "main": "./out/extension.js",
  "activationEvents": [
    "onCommand:b1.login"
  ],

  "contributes": {
    "commands": [
      {
        "command": "b1.login",
        "title": "LOGIN"
      },
      {
        "command": "b1.check",
        "title": "CHECK"
      }
    ],
    "menus": {
			"editor/title": [
				{
					"command": "b1.login",
					"group": "navigation"
				},
				{
					"command": "b1.check",
					"group": "navigation"
				}
			]
		},
    "configuration": {
      "title": "B1 Extension",
      "properties": {
        "b1.username": {
          "type": "string",
          "default": "",
          "description": "User name"
        },
        "b1.password": {
          "type": "string",
          "default": "",
          "description": "User password"
        },
        "b1.host_1": {
          "type": "string",
          "default": "https://tss.co.ua:7071",
          "description": "Problem server"
        },
        "b1.host_3": {
          "type": "string",
          "default": "https://tss.co.ua:7073",
          "description": "User server"
        }
      }
    }

  },
  "scripts": {
    "compile": "tsc -p ./"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
  }
}