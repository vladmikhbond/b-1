{
  "name": "b1",
  "displayName": "b1",
  "description": "IDE for PSS",
  "version": "1.0.0",
  "publisher": "your-name",
  "repository": {
    "type": "git",
    "url": "https://github.com/vladmikhbond/b-1.git"
  },
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "main": "./out/extension.js",
  "activationEvents": [
    "onCommand:b1.login",
    "onCommand:b1.check",
    "onCommand:b1.help"
  ],
  "contributes": {
    "commands": [
      {
        "command": "b1.login",
        "title": "b1: Login"
      },
      {
        "command": "b1.check",
        "title": "CHECK"
      },
      {
        "command": "b1.help",
        "title": "HELP"
      }
    ],
    "menus": {
			"editor/title": [
				{
					"command": "b1.check",
					"group": "navigation"
				},
				{
					"command": "b1.help",
					"group": "navigation"
				}
			]
		}

  },
  "scripts": {
    "compile": "tsc -p ./"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
  }
}